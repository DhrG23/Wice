<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="Wice.App"
             x:DataType="local:App"
             xmlns:local="clr-namespace:Wice"> 
    <TrayIcon.Icons>
        <TrayIcons>
            <TrayIcon Icon="/Assets/wice-logo.ico" 
                      ToolTipText="Wice Shell">
                <TrayIcon.Menu>
                    <NativeMenu>
                        <NativeMenuItem Header="Settings" Click="OnSettingsClick"/>
                        <NativeMenuItem Header="Restart Shell" Click="OnRestartClick"/>
                        
                        <NativeMenuItemSeparator/>
                        
                        <NativeMenuItem Header="Exit Wice" Click="OnExitClick"/>
                    </NativeMenu>
                </TrayIcon.Menu>
            </TrayIcon>
        </TrayIcons>
    </TrayIcon.Icons>
</Application>