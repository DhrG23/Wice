<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:widgets="using:Wice.Views.Widgets"
        x:Class="Wice.Views.TopBarWindow"
        Title="Wice Top Bar" Height="40"
        SystemDecorations="None" 
        Topmost="True"
        Background="Transparent" 
        TransparencyLevelHint="Transparent"
        WindowStartupLocation="Manual">

    <Grid Background="#CC1E1E1E">
        <!-- Placeholder for your modular widgets -->
        <TextBlock Text="Wice Top Bar" Foreground="White" 
                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
    </Grid>
</Window>